{
  "expo": {
    "name": "Noor360",
    "slug": "noor360",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1224"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.noor360.app",
      "infoPlist": {
        "ExpoLocalization_supportsRTL": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B1224"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.noor360.app",
      "allowBackup": false,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#C9A84C",
          "sounds": [
            "./assets/audio/adhan.mp3",
            "./assets/audio/adhan_madinah.mp3",
            "./assets/audio/simple_tone.mp3"
          ]
        }
      ],
      "expo-sqlite"
    ],
    "extra": {
      "supportsRTL": true,
      "router": {},
      "eas": {
        "projectId": "20b29f68-5a4e-411e-aa20-aa6cf6b8e0c5"
      }
    },
    "owner": "shoaib08"
  }
}
